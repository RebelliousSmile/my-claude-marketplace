{
  "$schema": "https://json.schemastore.org/claude-code-marketplace.json",
  "name": "my-marketplace",
  "version": "1.0.0",
  "description": "Local marketplace — personal overlay on the AIDD framework",
  "owner": {
    "name": "François-Xavier Guillois"
  },
  "plugins": [
