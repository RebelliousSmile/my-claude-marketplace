{
  "color": {
    "brand": {
      "primary": { "$type": "color", "$value": "#2563eb" }
    },
    "neutral": {
      "50":  { "$type": "color", "$value": "#f7f8fa" },
      "900": { "$type": "color", "$value": "#11151c" }
    },
    "semantic": {
      "background": { "$type": "color", "$value": "{color.neutral.50}" },
      "surface":    { "$type": "color", "$value": "#ffffff" },
      "text":       { "$type": "color", "$value": "{color.neutral.900}" }
    }
  },
  "font": {
    "size": {
      "body": { "$type": "dimension", "$value": "1rem" },
      "lg":   { "$type": "dimension", "$value": "1.125rem" }
    }
  },
  "space": {
    "4":  { "$type": "dimension", "$value": "1rem" },
    "8":  { "$type": "dimension", "$value": "2rem" }
  }
}
