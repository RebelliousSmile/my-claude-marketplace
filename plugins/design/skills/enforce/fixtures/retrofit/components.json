{
  "$schema": "design/references/manifest-schema#",
  "$version": "1.0.0",
  "mode": "bem",
  "components": {
    "btn": {
      "base": "btn",
      "elements": {
        "icon":  "btn__icon",
        "label": "btn__label"
      },
      "modifiers": {
        "primary":   "btn--primary",
        "secondary": "btn--secondary"
      },
      "backgrounds": ["color.semantic.background", "color.semantic.surface"],
      "a11y": { "role": "button", "requires": [] }
    },
    "card": {
      "base": "card",
      "elements": {
        "media": "card__media",
        "body":  "card__body",
        "title": "card__title"
      },
      "modifiers": {
        "featured": "card--featured"
      },
      "backgrounds": ["color.semantic.surface"],
      "a11y": { "role": "article", "requires": [] }
    },
    "nav": {
      "base": "nav",
      "elements": {
        "link": "nav__link"
      },
      "modifiers": {},
      "backgrounds": ["color.semantic.background"],
      "a11y": { "role": "navigation", "requires": [] }
    }
  }
}
